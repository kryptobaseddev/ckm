        }
      ],
      "outputs": {
        "type": {
          "canonical": "boolean"
        },
        "description": "True if the version is valid."
      }
    }
  ],
  "configSchema": [
    {
      "key": "calver.format",
      "type": {
        "canonical": "string",
        "original": "CalVerFormat"
      },
      "description": "Calendar format for version strings.",
      "default": "YYYY.MM.DD",
      "required": true
