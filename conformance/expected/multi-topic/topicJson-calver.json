{
  "name": "calver",
  "summary": "Configures CalVer validation rules.",
  "concepts": [
    {
      "id": "concept-calver-config",
      "name": "CalVerConfig",
      "slug": "calver",
      "what": "Configures CalVer validation rules.",
      "tags": [
        "config"
      ],
      "properties": [
        {
          "name": "format",
          "type": {
            "canonical": "string",
            "original": "CalVerFormat"
          },
          "description": "Calendar format for version strings.",
          "required": true,
          "default": "YYYY.MM.DD"
        }
      ]
    }
  ],
  "operations": [
    {
      "id": "op-validate-calver",
      "name": "validateCalVer",
      "what": "Validates a calver version string.",
      "tags": [
        "calver"
      ],
      "inputs": [
        {
          "name": "version",
          "type": {
            "canonical": "string"
          },
