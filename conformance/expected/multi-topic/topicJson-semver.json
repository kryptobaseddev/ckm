  ],
  "configSchema": [
    {
      "key": "semver.allowVPrefix",
      "type": {
        "canonical": "boolean"
      },
      "description": "Tolerates a leading v prefix.",
      "required": true
    }
  ],
  "constraints": [
    {
      "id": "constraint-valid-semver",
      "rule": "Version must conform to SemVer 2.0.0 specification.",
